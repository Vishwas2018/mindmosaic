# Hoist dev toolchain binaries to root node_modules/.bin so workspace package
# scripts (tsc, eslint, vitest) can find them without per-workspace devDependencies.
# Targeted patterns only — do not escalate to shamefully-hoist without a real break
# and an ADR update. See ADR-0002.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=typescript
public-hoist-pattern[]=*vitest*
strict-peer-dependencies=false
auto-install-peers=true
