# ==============================================================================
# MindMosaic — E2E gate environment reference
# Copy to .env.e2e (gitignored) and fill in real values before running:
#   scripts/seed-e2e.ts      (pnpm tsx scripts/seed-e2e.ts)
#   scripts/rls-check-e2e.sql (psql "$DATABASE_URL" -f scripts/rls-check-e2e.sql)
#   pnpm --filter @mm/web e2e (Playwright 20 specs)
#
# NEVER commit this file with real values — it is an example template only.
# See ISSUE-0037 for the pre-commit secret guard that enforces this.
# ==============================================================================

# ── Supabase connection ────────────────────────────────────────────────────────
# Local dev:  retrieve from `npx supabase status` after `npx supabase start`
# Preview:    Supabase Dashboard → Project Settings → API

# PostgREST + Edge Functions base (no trailing slash)
SUPABASE_URL=https://your-project.supabase.co

# Service-role key — used by seed-e2e.ts (bypasses RLS; keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anon key — used by Playwright specs (public; still keep out of VCS)
# Note: specs read E2E_SUPABASE_ANON (not SUPABASE_ANON_KEY)
E2E_SUPABASE_ANON=your-anon-key

# ── Playwright specs ──────────────────────────────────────────────────────────

# Next.js app URL (no trailing slash)
E2E_WEB_URL=http://localhost:3000

# Edge Functions base URL (no trailing slash)
# Local:   http://127.0.0.1:54321/functions/v1
# Preview: https://your-project.supabase.co/functions/v1
E2E_BASE_URL=http://127.0.0.1:54321/functions/v1

# Supabase REST URL — used by session-flow.spec.ts outbox assertion (optional)
# Local:   http://127.0.0.1:54321
# Preview: https://your-project.supabase.co
E2E_SUPABASE_URL=http://127.0.0.1:54321

# Service-role key alias for session-flow.spec.ts outbox query (optional)
E2E_TEST_SERVICE_ROLE=your-service-role-key

# Pathway UUID — output by seed-e2e.ts after first successful run
# Set this to the pathway_id printed by seed-e2e.ts read-back step 2.
E2E_TEST_PATHWAY_ID=00000000-e2e0-0000-0000-000000000002

# Seed student ID — used by teacher-student-detail.spec.ts (optional)
# Leave blank unless you need the "page structure" test to run.
E2E_SEED_STUDENT_ID=

# ── rls-check-e2e.sql ─────────────────────────────────────────────────────────
# Full psql connection string — must connect as a superuser role (postgres).
# rls-check-e2e.sql GUARDs against running as authenticated (false-green risk).
# Local:   postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Preview: postgresql://postgres:YOUR_DB_PASSWORD@db.your-project.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
